{
  "input": "../out/openverse-cat.jpg",
  "output": "../out/cat-with-mail-icon.png",
  "format": "png",
  "operations": [
    {
      "op": "resize",
      "width": 1280
    },
    {
      "op": "composite",
      "input": "../out/mail.png",
