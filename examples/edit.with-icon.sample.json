      "top": 40,
      "opacity": 0.96,
      "tint": "#ffffff"
    },
    {
      "op": "text",
      "value": "newsletter hero draft",
      "gravity": "northwest",
      "left": 190,
      "top": 48,
      "fontSize": 44,
      "color": "#ffffff",
      "background": "rgba(20,20,20,0.50)",
      "padding": 18
    }
  ]
}
