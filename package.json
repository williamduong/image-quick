{
  "name": "image-quick",
  "version": "0.1.0",
  "description": "Three-layer image workflow CLI: open-licensed asset pull, non-destructive edits, and AI generation.",
  "license": "MIT",
  "author": "williamduong <duongtannghia@gmail.com>",
  "keywords": [
    "images",
    "openverse",
    "iconify",
    "prompt",
    "cli",
    "image-generation",
    "templates",
    "automation"
  ],
  "type": "module",
  "bin": {
    "image-quick": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "doctor": "tsx src/cli.ts doctor",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "sharp": "^0.34.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "tsx": "^4.20.1",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamduong/image-quick.git"
  },
  "bugs": {
    "url": "https://github.com/williamduong/image-quick/issues"
  },
  "homepage": "https://github.com/williamduong/image-quick#readme"
}
