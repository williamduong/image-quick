{
  "name": "image-quick",
  "version": "0.2.2",
  "description": "Development workspace for the image-quick CLI.",
  "private": true,
  "license": "MIT",
  "author": "williamduong <duongtannghia@gmail.com>",
  "keywords": [
    "images",
    "openverse",
    "iconify",
    "prompt",
    "cli",
    "image-generation",
    "templates",
    "automation"
  ],
  "type": "module",
  "bin": {
    "image-quick": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "doctor": "tsx src/cli.ts doctor",
    "smoke": "npm run build && node scripts/smoke-tests.mjs",
    "release:prepare": "npm run build && node scripts/prepare-release.mjs",
    "release:pack": "npm run release:prepare && node scripts/run-release-npm.mjs pack --dry-run",
    "release:check": "npm run smoke && npm run release:prepare && node scripts/run-release-npm.mjs publish --dry-run",
    "release:publish": "npm run release:prepare && node scripts/run-release-npm.mjs publish --access public",
    "pack:check": "npm run release:pack",
    "publish:check": "npm run release:check"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "sharp": "^0.34.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "tsx": "^4.20.1",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamduong/image-quick.git"
  },
  "bugs": {
    "url": "https://github.com/williamduong/image-quick/issues"
  },
  "homepage": "https://github.com/williamduong/image-quick#readme"
}
